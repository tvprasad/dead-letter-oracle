# LLM provider — choose one: azure_openai | anthropic | ollama (default: azure_openai)
LLM_PROVIDER=azure_openai

# Azure OpenAI — required when LLM_PROVIDER=azure_openai
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Anthropic — required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama — required when LLM_PROVIDER=ollama
# Run locally: ollama serve && ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3
